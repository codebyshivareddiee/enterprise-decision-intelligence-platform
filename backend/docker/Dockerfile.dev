# syntax=docker/dockerfile:1.7
# ──────────────────────────────────────────────────────────────────────────────
# Development image — installs dev dependencies and mounts source as a volume
# ──────────────────────────────────────────────────────────────────────────────
FROM python:3.11-slim AS dev

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app

COPY pyproject.toml requirements.txt ./

# Install runtime + dev dependencies
RUN uv venv /opt/venv && \
    UV_PROJECT_ENVIRONMENT=/opt/venv uv pip install --no-cache -r requirements.txt && \
    UV_PROJECT_ENVIRONMENT=/opt/venv uv pip install --no-cache \
        pytest pytest-asyncio pytest-cov httpx ruff black mypy pre-commit

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
