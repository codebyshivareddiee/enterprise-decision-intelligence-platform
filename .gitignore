# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Enterprise Decision Intelligence Platform
# ──────────────────────────────────────────────────────────────────────────────

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env
.env.bak
/opt/venv/

# ── uv ───────────────────────────────────────────────────────────────────────
.uv/
uv.lock

# ── Secrets / Environment Variables ─────────────────────────────────────────
.env
*.env
!.env.example

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/
nosetests.xml
test-results/

# ── Linting / Formatting ─────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.black_cache/

# ── Docker ───────────────────────────────────────────────────────────────────
*.dockerignore

# ── IDEs / Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Node (for frontend) ──────────────────────────────────────────────────────
node_modules/
.next/
dist/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
# ── Frontend Specific ────────────────────────────────────────────────────────
frontend/node_modules/
